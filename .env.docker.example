# QuickQuote Docker runtime variables.
# Copy this file to .env on the cloud server, then fill in real secrets.
# Do not commit or share the filled .env file.

# App
APP_NAME=QuickQuote
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=*
FRONTEND_PORT=3000
API_BASE_URL=/api/v1

# Runtime storage inside backend container
UPLOAD_DIR=/app/uploads
QUOTE_ARCHIVE_DIR=/app/data
MAX_FILE_SIZE_MB=10

# Order goods database: bf_jushuitan_order_goods
ORDER_DB_HOST=
ORDER_DB_PORT=3306
ORDER_DB_USER=
ORDER_DB_PASSWORD=
ORDER_DB_NAME=

# Purchase records database: purchase_records
PURCHASE_DB_HOST=
PURCHASE_DB_PORT=3306
PURCHASE_DB_USER=
PURCHASE_DB_PASSWORD=
PURCHASE_DB_NAME=

# LLM
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
MODEL_SQL=gpt-4o-mini
MODEL_THINK=gpt-4.1-mini
LLM_TIMEOUT=120

# Workflow limits
NODE_PARSE_TIMEOUT=60
NODE_SQL_TIMEOUT=180
NODE_REASON_TIMEOUT=60
NODE_MAX_RETRIES=2
NODE_SQL_MAX_CONCURRENCY=2
NODE_SQL_MAX_ITEMS=2000
QUERY_CANDIDATE_LIMIT=5
PURCHASE_CANDIDATE_SCAN_LIMIT=100
MAX_INPUT_ITEMS=2000
JOB_INPUT_THRESHOLD=100
ORDER_QUERY_MAX_CONCURRENCY=5
EXTERNAL_QUERY_MAX_CONCURRENCY=10
CACHE_TTL_SECONDS=120

# Multi-source database candidate search
DB_CANDIDATE_BATCH_SIZE=25
DB_CANDIDATE_QUERY_TIMEOUT=8
DB_CANDIDATE_LIMIT_MULTIPLIER=4

# Jushuitan
JUSHUITAN_ENV=prod
JUSHUITAN_BASE_URL=https://openapi.jushuitan.com
JUSHUITAN_BASE_URL_TEST=https://dev-api.jushuitan.com
JUSHUITAN_APP_KEY=
JUSHUITAN_APP_SECRET=
JUSHUITAN_AUTH_CODE=
JUSHUITAN_ACCESS_TOKEN=
JUSHUITAN_REFRESH_TOKEN=
JUSHUITAN_ENABLE_TOKEN_CACHE=true
JUSHUITAN_TOKEN_CACHE_FILE=/app/data/.jushuitan_token_cache.json
JUSHUITAN_AUTH_CODE_RANDOM_LENGTH=6
JUSHUITAN_QUERY_MAX_CONCURRENCY=10
JUSHUITAN_QUERY_MAX_PAGES=2
JUSHUITAN_INVENTORY_MAX_CONCURRENCY=3
JUSHUITAN_INVENTORY_MAX_WAREHOUSES=4
JUSHUITAN_INVENTORY_WMS_CO_IDS=
JUSHUITAN_QUERY_CACHE_TTL_SECONDS=300
JUSHUITAN_AUTH_INIT_PATH=/openWeb/auth/getInitToken
JUSHUITAN_AUTH_INIT_PATH_TEST=/openWebIsv/auth/getInitToken
JUSHUITAN_SKU_QUERY_PATH=/open/sku/query
JUSHUITAN_INVENTORY_QUERY_PATH=/open/inventory/query
JUSHUITAN_PURCHASE_IN_QUERY_PATH=/open/purchasein/query
JUSHUITAN_DYNAMIC_COST_LOOKBACK_DAYS=30
JUSHUITAN_DYNAMIC_COST_MAX_PAGES=20
JUSHUITAN_DEFAULT_WMS_CO_ID=0
JUSHUITAN_TIMEOUT=30
JUSHUITAN_MAX_ITEMS=100
JUSHUITAN_PAGE_SIZE=100
JUSHUITAN_CHARSET=utf-8
JUSHUITAN_VERSION=2
JUSHUITAN_SIGN_ALGO=md5
JUSHUITAN_SIGN_LOWERCASE=true
